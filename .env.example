# Copy this file to .env and fill in the values.
# Phase 1 (retro shell only) runs without these — app shows a stub notice.

# Supabase project (create at https://supabase.com/dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Modal worker endpoint (Phase 3). Leave blank until the worker is deployed.
EXPO_PUBLIC_WORKER_URL=
